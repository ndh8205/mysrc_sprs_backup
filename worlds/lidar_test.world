<?xml version="1.0"?>
<sdf version="1.9">
  <world name="lidar_test_world">

    <gravity>0 0 0</gravity>

    <physics name="dart_physics" type="dart" default="true">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
    </physics>

    <scene>
      <background>0 0 0 1</background>
      <ambient>0.1 0.1 0.1 1</ambient>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <!-- 태양광 -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>1.0 0.95 0.8 1</diffuse>
      <specular>1.0 1.0 1.0 1</specular>
      <intensity>5</intensity>
      <direction>0 0 -1</direction>
    </light>

    <!-- LiDAR 장착 위성 (원점) -->
    <include>
      <uri>model://controla_prototype_1</uri>
      <name>controla_prototype_1</name>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- 타겟: LiDAR는 +Y 방향 (yaw=π/2), 3m 거리 배치 -->
    <include>
      <uri>model://gaim_target_3u</uri>
      <name>lidar_target</name>
      <pose>0 3 0 0 0 0</pose>
      <static>true</static>
    </include>

    <!-- 추가 타겟: +X 방향 5m (LiDAR FOV 경계 확인용) -->
    <include>
      <uri>model://intel_sat_dummy</uri>
      <name>lidar_target_2</name>
      <pose>0 5 0.5 0 0 0</pose>
      <static>true</static>
    </include>

    <!-- GUI -->
    <gui fullscreen="0">
      <plugin filename="GzScene3D" name="3D View">
        <engine>ogre2</engine>
        <scene>scene</scene>
        <background_color>0 0 0 1</background_color>
        <camera_pose>-2 -5 3 0 0.5 1.2</camera_pose>
      </plugin>
      <plugin filename="ImageDisplay" name="Camera View">
        <gz-gui>
          <title>Camera</title>
          <property type="bool" key="showTitleBar">true</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <topic>controla_prototype_1/camera</topic>
      </plugin>
    </gui>

    <!-- 시스템 플러그인 -->
    <plugin filename="libgz-sim-sensors-system.so" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="libgz-sim-physics-system.so" name="gz::sim::systems::Physics"/>
    <plugin filename="libgz-sim-user-commands-system.so" name="gz::sim::systems::UserCommands"/>
    <plugin filename="libgz-sim-scene-broadcaster-system.so" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="libgz-sim-imu-system.so" name="gz::sim::systems::Imu"/>

  </world>
</sdf>
