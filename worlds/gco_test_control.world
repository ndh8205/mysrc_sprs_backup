<?xml version="1.0"?>
<sdf version="1.9">
  <world name="space_world">
    <gui fullscreen="0">
      <plugin filename="GzScene3D" name="3D View">
        <engine>ogre2</engine>
        <scene>scene</scene>
        <background_color>0 0 0 1</background_color>
        <camera_pose>10 -10 10 0 0.6 2.3</camera_pose>
      </plugin>
      
      <plugin filename="ImageDisplay" name="Image Display">
        <gz-gui>
          <title>Camera View</title>
          <property type="bool" key="showTitleBar">true</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <topic>nasa_satellite2/camera</topic>
        <refresh_rate_hz>60</refresh_rate_hz>
      </plugin>
    </gui>

    <scene>
      <background>0 0 0 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <gravity>0 0 0</gravity>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 100 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
      <direction>0 0 -1</direction>
    </light>

    <include>
      <uri>model://nasa_satellite2</uri>
      <name>nasa_satellite2</name>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <include>
      <uri>model://nasa_satellite3</uri>
      <name>nasa_satellite3</name>
      <pose>0 12 0 0 0 0</pose>
      <plugin filename="libgz-sim-odometry-publisher-system.so" name="gz::sim::systems::OdometryPublisher"/>
      <plugin filename="libgz-sim-apply-force-system.so" name="gz::sim::systems::ApplyForce"/>
    </include>

    <include>
      <uri>model://nasa_satellite4</uri>
      <name>nasa_satellite4</name>
      <pose>6 0 10.3923 0 0 0</pose>
      <plugin filename="libgz-sim-odometry-publisher-system.so" name="gz::sim::systems::OdometryPublisher"/>
      <plugin filename="libgz-sim-apply-force-system.so" name="gz::sim::systems::ApplyForce"/>
    </include>
    
    <plugin filename="libgz-sim-sensors-system.so" name="gz::sim::systems::Sensors"/>
    <plugin filename="libgz-sim-physics-system.so" name="gz::sim::systems::Physics"/>
    <plugin filename="libgz-sim-user-commands-system.so" name="gz::sim::systems::UserCommands"/>
    <plugin filename="libgz-sim-scene-broadcaster-system.so" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="libgz-sim-imu-system.so" name="gz::sim::systems::Imu"/>
  </world>
</sdf>