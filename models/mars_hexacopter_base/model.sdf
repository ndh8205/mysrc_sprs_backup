<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mars Hexacopter Base Model + 2x Parallel VSCMG
  5.0 kg total, 6 rotors × 2-blade, R=0.44m
  CMG: 2x parallel VSCMG (gimbal axis Y, spin axis X)
  Design reference: docs/mars_hexacopter_design.md
  Parameter verification: scripts/mars_hexacopter_design_calc.py

  Rotor layout (top view, CCW positive yaw):
        2(CCW)   1(CW)
          \       /
    3(CW) -- HUB -- 0(CCW)
          /       \
        4(CCW)   5(CW)

  Angles: 0=0°, 1=60°, 2=120°, 3=180°, 4=240°, 5=300°
  Turning: 0,2,4=CCW  1,3,5=CW  (yaw balanced)

  CMG layout (inside hub):
    CMG1: +X side (pos=[+0.05, 0, 0])
    CMG2: -X side (pos=[-0.05, 0, 0])
    Gimbal axis: Y, Spin axis: X
    Same parameters as cubesat_cmg (MATLAB CMG_sim.m verified)
-->
<sdf version='1.9'>
  <model name='mars_hexacopter_base'>
    <pose>0 0 0.22 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ============================================ -->
    <!-- base_link: hub + arms + motors + landing gear -->
    <!-- ============================================ -->
    <link name="base_link">
      <inertial>
        <!-- 4.670 - 0.30 (2x CMG: 2×0.05 gimbal + 2×0.1 wheel) = 4.370 -->
        <mass>4.370</mass>
        <inertia>
          <ixx>0.39558</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.39558</iyy>
          <iyz>0</iyz>
          <izz>0.78650</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay/>

      <!-- Central hub (cylinder r=0.15, h=0.10) -->
      <visual name="hub_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>

      <!-- Arm 0: 0° -->
      <visual name="arm_0_visual">
        <pose>0.55 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 1: 60° -->
      <visual name="arm_1_visual">
        <pose>0.275 0.47631 0 0 0 1.0472</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 2: 120° -->
      <visual name="arm_2_visual">
        <pose>-0.275 0.47631 0 0 0 2.0944</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 3: 180° -->
      <visual name="arm_3_visual">
        <pose>-0.55 0 0 0 0 3.1416</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 4: 240° -->
      <visual name="arm_4_visual">
        <pose>-0.275 -0.47631 0 0 0 4.1888</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 5: 300° -->
      <visual name="arm_5_visual">
        <pose>0.275 -0.47631 0 0 0 5.2360</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Motor pods (small cylinders at arm tips) -->
      <visual name="motor_pod_0">
        <pose>0.95 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="motor_pod_1">
        <pose>0.475 0.82272 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="motor_pod_2">
        <pose>-0.475 0.82272 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="motor_pod_3">
        <pose>-0.95 0 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="motor_pod_4">
        <pose>-0.475 -0.82272 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>
      <visual name="motor_pod_5">
        <pose>0.475 -0.82272 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.03</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.3 0.1 0.1 1</ambient><diffuse>0.5 0.15 0.15 1</diffuse></material>
      </visual>

      <!-- Landing gear: 3 legs at 0°, 120°, 240° (120° symmetric) -->
      <!-- Leg 0: 0° (x+ direction) -->
      <visual name="leg_0_visual">
        <pose>0.15 0 -0.135 0 0 0</pose>
        <geometry><box><size>0.015 0.015 0.17</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <!-- Leg 1: 120° -->
      <visual name="leg_1_visual">
        <pose>-0.075 0.130 -0.135 0 0 0</pose>
        <geometry><box><size>0.015 0.015 0.17</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <!-- Leg 2: 240° -->
      <visual name="leg_2_visual">
        <pose>-0.075 -0.130 -0.135 0 0 0</pose>
        <geometry><box><size>0.015 0.015 0.17</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <!-- Landing gear feet: 3 bars perpendicular to radial, all same size -->
      <visual name="foot_0">
        <pose>0.15 0 -0.22 0 0 1.5708</pose>
        <geometry><box><size>0.30 0.015 0.015</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <visual name="foot_1">
        <pose>-0.075 0.130 -0.22 0 0 0.5236</pose>
        <geometry><box><size>0.30 0.015 0.015</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <visual name="foot_2">
        <pose>-0.075 -0.130 -0.22 0 0 -0.5236</pose>
        <geometry><box><size>0.30 0.015 0.015</size></box></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>

      <!-- Collision: central hub -->
      <collision name="hub_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <surface>
          <contact><ode><min_depth>0.001</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode/></friction>
        </surface>
      </collision>
      <!-- Collision: landing gear feet (3× symmetric, thicker for reliable ground contact) -->
      <collision name="foot_0_collision">
        <pose>0.15 0 -0.20 0 0 1.5708</pose>
        <geometry><box><size>0.30 0.04 0.06</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.002</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <collision name="foot_1_collision">
        <pose>-0.075 0.130 -0.20 0 0 0.5236</pose>
        <geometry><box><size>0.30 0.04 0.06</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.002</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
      <collision name="foot_2_collision">
        <pose>-0.075 -0.130 -0.20 0 0 -0.5236</pose>
        <geometry><box><size>0.30 0.04 0.06</size></box></geometry>
        <surface>
          <contact><ode><min_depth>0.002</min_depth><max_vel>0</max_vel></ode></contact>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>

      <!-- Sensors (same pattern as x500_base) -->
      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.00686</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure><noise type="gaussian"><mean>0</mean><stddev>3</stddev></noise></pressure>
        </air_pressure>
      </sensor>
      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <!-- ============================================ -->
    <!-- Rotor 0: 0° (CCW) -->
    <!-- ============================================ -->
    <link name="rotor_0">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
      <velocity_decay/>
      <pose>0.95 0 0.06 0 0 0</pose>
      <inertial>
        <mass>0.055</mass>
        <inertia>
          <ixx>1.0e-05</ixx>
          <iyy>3.549333e-03</iyy>
          <izz>3.549333e-03</izz>
        </inertia>
      </inertial>
      <!-- 2-blade propeller (span=0.88m, chord=0.10m, t=0.005m) -->
      <visual name="rotor_0_blade">
        <geometry>
          <box><size>0.88 0.10 0.005</size></box>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 0.9</ambient>
          <diffuse>0.45 0.45 0.45 0.9</diffuse>
        </material>
      </visual>
      <visual name="rotor_0_hub">
        <geometry>
          <cylinder><radius>0.02</radius><length>0.015</length></cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
      </axis>
    </joint>

    <!-- ============================================ -->
    <!-- Rotor 1: 60° (CW) -->
    <!-- ============================================ -->
    <link name="rotor_1">
      <gravity>true</gravity>
      <self_collide>false</self_collide>
