    <!-- ============================================ -->
    <!-- CMG 1: +X side (same as cubesat_cmg) -->
    <!-- MATLAB: pos=[0.05;0;0], a=[0;1;0], s0=[1;0;0] -->
    <!-- ============================================ -->
    <link name="cmg1_gimbal">
      <pose relative_to="base_link">0.05 0 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>1e-6</ixx> <iyy>1e-6</iyy> <izz>1e-6</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Gimbal shaft (visual scaled for hexacopter, inertia unchanged) -->
      <visual name="cmg1_gimbal_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.12</length></cylinder></geometry>
        <material>
          <ambient>0.2 0.2 0.9 1</ambient>
          <diffuse>0.3 0.3 1.0 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="cmg1_wheel">
      <pose relative_to="cmg1_gimbal">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>3.65e-5</ixx> <iyy>2e-5</iyy> <izz>2e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Wheel disk (visual scaled for hexacopter) -->
      <visual name="cmg1_wheel_visual">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material>
          <ambient>0.9 0.2 0.2 1</ambient>
          <diffuse>1.0 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <visual name="cmg1_stripe_y">
        <geometry><box><size>0.025 0.095 0.008</size></box></geometry>
        <material><ambient>1.0 1.0 0.2 1</ambient><diffuse>1.0 1.0 0.3 1</diffuse></material>
      </visual>
      <visual name="cmg1_stripe_z">
        <geometry><box><size>0.025 0.008 0.095</size></box></geometry>
        <material><ambient>1.0 1.0 1.0 1</ambient><diffuse>1.0 1.0 1.0 1</diffuse></material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- CMG 2: -X side -->
    <!-- MATLAB: pos=[-0.05;0;0], a=[0;1;0], s0=[1;0;0] -->
    <!-- ============================================ -->
    <link name="cmg2_gimbal">
      <pose relative_to="base_link">-0.05 0 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>1e-6</ixx> <iyy>1e-6</iyy> <izz>1e-6</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Gimbal shaft (visual scaled for hexacopter, inertia unchanged) -->
      <visual name="cmg2_gimbal_visual">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.008</radius><length>0.12</length></cylinder></geometry>
        <material>
          <ambient>0.2 0.9 0.2 1</ambient>
          <diffuse>0.3 1.0 0.3 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="cmg2_wheel">
      <pose relative_to="cmg2_gimbal">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>3.65e-5</ixx> <iyy>2e-5</iyy> <izz>2e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Wheel disk (visual scaled for hexacopter) -->
      <visual name="cmg2_wheel_visual">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.05</radius><length>0.02</length></cylinder></geometry>
        <material>
          <ambient>0.9 0.2 0.2 1</ambient>
          <diffuse>1.0 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <visual name="cmg2_stripe_y">
        <geometry><box><size>0.025 0.095 0.008</size></box></geometry>
        <material><ambient>1.0 1.0 0.2 1</ambient><diffuse>1.0 1.0 0.3 1</diffuse></material>
      </visual>
      <visual name="cmg2_stripe_z">
        <geometry><box><size>0.025 0.008 0.095</size></box></geometry>
        <material><ambient>1.0 1.0 1.0 1</ambient><diffuse>1.0 1.0 1.0 1</diffuse></material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- CMG Joints -->
    <!-- ============================================ -->
    <joint name="cmg1_gimbal_joint" type="revolute">
      <parent>base_link</parent>
      <child>cmg1_gimbal</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>10</effort> <velocity>2.0</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg1_wheel_joint" type="revolute">
      <parent>cmg1_gimbal</parent>
      <child>cmg1_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>1</effort> <velocity>2100</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg2_gimbal_joint" type="revolute">
      <parent>base_link</parent>
      <child>cmg2_gimbal</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>10</effort> <velocity>2.0</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg2_wheel_joint" type="revolute">
      <parent>cmg2_gimbal</parent>
      <child>cmg2_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>1</effort> <velocity>2100</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

  </model>
</sdf>
