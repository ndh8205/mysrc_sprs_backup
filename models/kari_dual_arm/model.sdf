<?xml version="1.0"?>
<sdf version="1.9">
  <model name="kari_dual_arm">
    <self_collide>true</self_collide>

    <!-- ========== SATELLITE BODY ========== -->
    <link name="satellite_body">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>500</mass>
        <inertia>
          <ixx>260</ixx>
          <ixy>-0.2</ixy>
          <ixz>0.6</ixz>
          <iyy>280</iyy>
          <iyz>4</iyz>
          <izz>170</izz>
        </inertia>
      </inertial>

      <!-- Satellite Body (황금색) -->
      <visual name="satellite_body_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>meshes/satellite_body.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.85 0.65 0.13 1</ambient>
          <diffuse>0.85 0.65 0.13 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>

      <!-- Satellite Panel (어두운 파란색) -->
      <visual name="satellite_panel_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>meshes/satellite_panel.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.1 0.2 0.5 1</ambient>
          <diffuse>0.1 0.2 0.5 1</diffuse>
          <specular>0.2 0.2 0.2 1</specular>
        </material>
      </visual>

      <!-- Satellite Front (흰색) -->
      <visual name="satellite_front_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>meshes/satellite_front.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.95 0.95 0.95 1</ambient>
          <diffuse>0.95 0.95 0.95 1</diffuse>
          <specular>0.5 0.5 0.5 1</specular>
        </material>
      </visual>

      <!-- Collision: Body (중앙 본체) -->
      <collision name="satellite_body_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>2.0 2.4 2.4</size>
          </box>
        </geometry>
      </collision>

      <!-- Collision: Panel Left (+Y) -->
      <collision name="satellite_panel_L_collision">
        <pose>0 3.05 0 0 0 0</pose>
        <geometry>
          <box>
            <size>2.0 3.05 0.05</size>
          </box>
        </geometry>
      </collision>

      <!-- Collision: Front (전방부 전체) -->
      <collision name="satellite_front_collision">
        <pose>1.575 0 0 0 0 0</pose>
        <geometry>
          <box>
            <size>0.8 1.8 1.8</size>
          </box>
        </geometry>
      </collision>

      <collision name="satellite_panel_R_collision">
        <pose>0 -3.05 0 0 0 0</pose>
        <geometry>
          <box>
            <size>2.0 3.05 0.05</size>
          </box>
        </geometry>
      </collision>

      <!-- ========== SENSORS ========== -->
      
      <!-- IMU (Gyro only) -->
      <sensor name="servicer_imu" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <visualize>false</visualize>
        <topic>/servicer/imu</topic>
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </z>
          </angular_velocity>
        </imu>
      </sensor>

      <!-- Docking Camera Left (+Y side) -->
      <sensor name="docking_cam_L" type="camera">
        <pose>1.9 0.7 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.1868</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>50000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <visualize>true</visualize>
        <topic>/servicer/docking_cam_L/image_raw</topic>
      </sensor>

      <!-- Docking Camera Right (-Y side) -->
      <sensor name="docking_cam_R" type="camera">
        <pose>1.9 -0.7 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.1868</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>50000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>15</update_rate>
        <visualize>true</visualize>
        <topic>/servicer/docking_cam_R/image_raw</topic>
      </sensor>

      <!-- WFOV Left (front top, outer) -->
      <sensor name="wfov_L" type="camera">
        <pose>2.0 0.3 0.8 0 0 0</pose>
        <camera>
          <horizontal_fov>0.3403</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>5000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>4</update_rate>
        <visualize>false</visualize>
        <topic>/servicer/wfov_L/image_raw</topic>
      </sensor>

      <!-- NFOV Left (front top, inner) -->
      <sensor name="nfov_L" type="camera">
        <pose>2.0 0.1 0.8 0 0 0</pose>
        <camera>
          <horizontal_fov>0.1</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>1.0</near>
            <far>50000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>4</update_rate>
        <visualize>false</visualize>
        <topic>/servicer/nfov_L/image_raw</topic>
      </sensor>

      <!-- NFOV Right (front top, inner) -->
      <sensor name="nfov_R" type="camera">
        <pose>2.0 -0.1 0.8 0 0 0</pose>
        <camera>
          <horizontal_fov>0.1</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>1.0</near>
            <far>50000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>4</update_rate>
        <visualize>false</visualize>
        <topic>/servicer/nfov_R/image_raw</topic>
      </sensor>

      <!-- WFOV Right (front top, outer) -->
      <sensor name="wfov_R" type="camera">
        <pose>2.0 -0.3 0.8 0 0 0</pose>
        <camera>
          <horizontal_fov>0.3403</horizontal_fov>
          <image>
            <width>1024</width>
            <height>1024</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>5000</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>4</update_rate>
        <visualize>false</visualize>
        <topic>/servicer/wfov_R/image_raw</topic>
      </sensor>
    </link>

    <!-- ################################################################## -->
    <!-- ==================== LEFT ARM (+Y) ==================== -->
    <!-- ################################################################## -->

    <!-- ARM_L BASE -->
    <link name="arm_L_base">
      <pose relative_to="arm_L_mount">0 0 0 0 0 0</pose>
      <inertial>
        <pose>-0.00000965 -0.00003686 0.07767998 0 0 0</pose>
        <mass>3.3436</mass>
        <inertia>
          <ixx>0.00751250</ixx>
          <ixy>-0.00000006</ixy>
          <ixz>0.00000167</ixz>
          <iyy>0.00752435</iyy>
          <iyz>-0.00000111</iyz>
          <izz>0.00631252</izz>
        </inertia>
      </inertial>
      <visual name="arm_L_base_visual">
        <geometry>
          <mesh>
            <uri>model://kari_arm/meshes/ASM_J0.STL</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.75 0.75 0.75 1</ambient>
          <diffuse>0.75 0.75 0.75 1</diffuse>
        </material>
      </visual>
      <collision name="arm_L_base_collision">
