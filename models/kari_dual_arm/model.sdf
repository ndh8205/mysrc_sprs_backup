          <mesh>
            <uri>model://kari_arm/meshes/ASM_J0.STL</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <joint name="arm_L_mount" type="fixed">
      <pose relative_to="satellite_body">1.9 0.9 0 -1.5708 0 0</pose>
      <parent>satellite_body</parent>
      <child>arm_L_base</child>
    </joint>

    <!-- ARM_L LINK1 -->
    <link name="arm_L_link1">
