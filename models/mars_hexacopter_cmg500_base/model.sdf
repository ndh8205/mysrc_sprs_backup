        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_5_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_5</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e+16</lower><upper>1e+16</upper></limit>
        <dynamics><spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness></dynamics>
      </axis>
    </joint>

    <!-- ============================================ -->
    <!-- CMG 1: +X side — Mini CMG 500 -->
    <!-- Gimbal axis: Y, Spin axis: X -->
    <!-- ============================================ -->
    <link name="cmg1_gimbal">
      <pose relative_to="base_link">0.06 0 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.16</mass>
        <inertia>
          <ixx>5.0e-5</ixx> <iyy>5.0e-5</iyy> <izz>5.0e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Gimbal shaft (Y-axis, visible frame) -->
      <visual name="cmg1_gimbal_shaft">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.012</radius><length>0.10</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.0 0.8 1</ambient>
          <diffuse>0.1 0.1 1.0 1</diffuse>
        </material>
      </visual>
      <!-- Gimbal mounting brackets (±Y ends) -->
      <visual name="cmg1_bracket_top">
        <pose>0 0.045 0 0 0 0</pose>
        <geometry><box><size>0.04 0.01 0.04</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
      <visual name="cmg1_bracket_bot">
        <pose>0 -0.045 0 0 0 0</pose>
        <geometry><box><size>0.04 0.01 0.04</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
    </link>

    <link name="cmg1_wheel">
      <pose relative_to="cmg1_gimbal">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.28</mass>
        <inertia>
          <ixx>1.603e-4</ixx> <iyy>9.0e-5</iyy> <izz>9.0e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Flywheel disk (R=35mm, L=30mm) -->
      <visual name="cmg1_wheel_visual">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.035</radius><length>0.03</length></cylinder></geometry>
        <material>
          <ambient>0.9 0.2 0.2 1</ambient>
          <diffuse>1.0 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <!-- Cross stripes for rotation visualization (protrude beyond wheel disk) -->
      <visual name="cmg1_stripe_y">
        <geometry><box><size>0.04 0.065 0.008</size></box></geometry>
        <material><ambient>1.0 1.0 0.0 1</ambient><diffuse>1.0 1.0 0.1 1</diffuse></material>
      </visual>
      <visual name="cmg1_stripe_z">
        <geometry><box><size>0.04 0.008 0.065</size></box></geometry>
        <material><ambient>1.0 1.0 1.0 1</ambient><diffuse>1.0 1.0 1.0 1</diffuse></material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- CMG 2: -X side — Mini CMG 500 -->
    <!-- ============================================ -->
    <link name="cmg2_gimbal">
      <pose relative_to="base_link">-0.06 0 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.16</mass>
        <inertia>
          <ixx>5.0e-5</ixx> <iyy>5.0e-5</iyy> <izz>5.0e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Gimbal shaft (Y-axis, visible frame) -->
      <visual name="cmg2_gimbal_shaft">
        <pose>0 0 0 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.012</radius><length>0.10</length></cylinder></geometry>
        <material>
          <ambient>0.0 0.6 0.0 1</ambient>
          <diffuse>0.1 0.8 0.1 1</diffuse>
        </material>
      </visual>
      <!-- Gimbal mounting brackets (±Y ends) -->
      <visual name="cmg2_bracket_top">
        <pose>0 0.045 0 0 0 0</pose>
        <geometry><box><size>0.04 0.01 0.04</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
      <visual name="cmg2_bracket_bot">
        <pose>0 -0.045 0 0 0 0</pose>
        <geometry><box><size>0.04 0.01 0.04</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.4 0.4 0.4 1</diffuse></material>
      </visual>
    </link>

    <link name="cmg2_wheel">
      <pose relative_to="cmg2_gimbal">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.28</mass>
        <inertia>
          <ixx>1.603e-4</ixx> <iyy>9.0e-5</iyy> <izz>9.0e-5</izz>
          <ixy>0</ixy> <ixz>0</ixz> <iyz>0</iyz>
        </inertia>
      </inertial>
      <!-- Flywheel disk -->
      <visual name="cmg2_wheel_visual">
        <pose>0 0 0 0 1.5708 0</pose>
        <geometry><cylinder><radius>0.035</radius><length>0.03</length></cylinder></geometry>
        <material>
          <ambient>0.9 0.2 0.2 1</ambient>
          <diffuse>1.0 0.3 0.3 1</diffuse>
        </material>
      </visual>
      <!-- Cross stripes for rotation visualization (protrude beyond wheel disk) -->
      <visual name="cmg2_stripe_y">
        <geometry><box><size>0.04 0.065 0.008</size></box></geometry>
        <material><ambient>1.0 1.0 0.0 1</ambient><diffuse>1.0 1.0 0.1 1</diffuse></material>
      </visual>
      <visual name="cmg2_stripe_z">
        <geometry><box><size>0.04 0.008 0.065</size></box></geometry>
        <material><ambient>1.0 1.0 1.0 1</ambient><diffuse>1.0 1.0 1.0 1</diffuse></material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- CMG Joints — Mini CMG 500 limits -->
    <!-- ============================================ -->
    <joint name="cmg1_gimbal_joint" type="revolute">
      <parent>base_link</parent>
      <child>cmg1_gimbal</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>10</effort> <velocity>2.0</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg1_wheel_joint" type="revolute">
      <parent>cmg1_gimbal</parent>
      <child>cmg1_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>1</effort> <velocity>3200</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg2_gimbal_joint" type="revolute">
      <parent>base_link</parent>
      <child>cmg2_gimbal</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>10</effort> <velocity>2.0</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

    <joint name="cmg2_wheel_joint" type="revolute">
      <parent>cmg2_gimbal</parent>
      <child>cmg2_wheel</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-1e16</lower> <upper>1e16</upper>
          <effort>1</effort> <velocity>3200</velocity>
        </limit>
        <dynamics><damping>0.0</damping><friction>0.0</friction></dynamics>
      </axis>
    </joint>

  </model>
</sdf>
