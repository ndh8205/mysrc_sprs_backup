        <pose>0 0.31 0.06 0 0 0</pose>
        <geometry><box><size>0.02 0.025 0.02</size></box></geometry>
        <material><ambient>0.0 0.9 0.0 1</ambient><diffuse>0.0 1.0 0.0 1</diffuse></material>
      </visual>

      <!-- Z axis — Blue shaft -->
