        <pose>0 0.15 0.06 1.5708 0 0</pose>
        <geometry><cylinder><radius>0.006</radius><length>0.30</length></cylinder></geometry>
        <material><ambient>0.0 0.9 0.0 1</ambient><diffuse>0.0 1.0 0.0 1</diffuse></material>
      </visual>
      <!-- Y axis — Green arrowhead -->
