<?xml version="1.0" encoding="UTF-8"?>
<!--
  Mars Hexacopter Base Model + 2x Mini CMG 500 (Momentum Space)
  5.0 kg total, 6 rotors × 2-blade, R=0.44m
  CMG: 2x CSCMG (gimbal axis Y, spin axis X)

  Mini CMG 500 specs:
    Mass per unit:     0.44 kg
    Wheel MOI (spin):  1.603e-4 kg·m²
    Max wheel speed:   30000 RPM (3141.6 rad/s)
    Max angular mom.:  0.5 Nms
    Max torque:        1.0 Nm
    Gimbal rate:       2.0 rad/s
    Dimensions:        80×80×105 mm

  Reference:
    Yang et al., "Disturbance Robust Attitude Stabilization of
    Multirotors with Control Moment Gyros," Sensors 2024, 24, 8212

  Rotor layout (top view, CCW positive yaw):
        2(CCW)   1(CW)
          \       /
    3(CW) -- HUB -- 0(CCW)
          /       \
        4(CCW)   5(CW)

  CMG layout (inside hub):
    CMG1: +X side (pos=[+0.06, 0, 0])
    CMG2: -X side (pos=[-0.06, 0, 0])
    Gimbal axis: Y, Spin axis: X
-->
<sdf version='1.9'>
  <model name='mars_hexacopter_cmg500_base'>
    <pose>0 0 0.22 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ============================================ -->
    <!-- base_link: hub + arms + motors + landing gear -->
    <!-- Mass: 5.0 - 6×0.055(rotor) - 2×0.44(CMG) = 3.790 -->
    <!-- ============================================ -->
    <link name="base_link">
      <inertial>
        <mass>3.790</mass>
        <inertia>
          <ixx>0.34310</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.34310</iyy>
          <iyz>0</iyz>
          <izz>0.68200</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay/>

      <!-- Central hub (cylinder r=0.15, h=0.10) -->
      <visual name="hub_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.15</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.3 0.3 0.3 1</diffuse>
        </material>
      </visual>

      <!-- Arm 0: 0° -->
      <visual name="arm_0_visual">
        <pose>0.55 0 0 0 0 0</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 1: 60° -->
      <visual name="arm_1_visual">
        <pose>0.275 0.47631 0 0 0 1.0472</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 2: 120° -->
      <visual name="arm_2_visual">
        <pose>-0.275 0.47631 0 0 0 2.0944</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- Arm 3: 180° -->
      <visual name="arm_3_visual">
        <pose>-0.55 0 0 0 0 3.1416</pose>
        <geometry>
          <box><size>0.80 0.03 0.02</size></box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
